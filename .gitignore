# dependencies
node_modules/

# reference repos (not part of Claudbot)
openclaw-main/
NemoClaw-main/

# update command backups
.update-backup-*/

# logs
*.log

# secrets — never commit
.env

# generated / runtime files (machine-specific paths, regenerated on launch)
.claudbot/.mcp.json
.claudbot/channels.yaml
.claudbot/dream-log.md
.claudbot/channel-log.md
.claudbot/conversation-index.json
.claudbot/.pid
.claudbot/.restart
