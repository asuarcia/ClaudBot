{
  "name": "claudbot",
  "version": "0.2.0",
  "description": "Autonomous agent orchestrated by Claude Code, with sub-agents, WhatsApp/Telegram channels, and dreaming",
  "type": "module",
  "bin": {
    "claudbot": "./claudbot.mjs"
  },
  "scripts": {
    "setup":    "npm install && cd mcp-servers/claudbot-exec && npm install",
    "onboard":  "node scripts/onboard.mjs",
    "start":    "node claudbot.mjs",
    "channels": "node channel-server.mjs",
    "dream":    "node dream.mjs",
    "dream:watch": "node dream.mjs --watch"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "chalk": "^5.6.2",
    "express": "^4.21.2",
    "yaml": "^2.9.0"
  }
}
