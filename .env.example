# Claudbot environment variables
# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your values:
#     cp .env.example .env        (macOS/Linux)
#     Copy-Item .env.example .env (Windows PowerShell)
#
# The real ".env" is gitignored and must NEVER be committed.
# `claudbot onboard` writes most of these for you automatically.
# ---------------------------------------------------------------------------

# ── Fallback provider + sub-agents (required for fallback/channels/dream) ──
# Used when Claude Code hits its rate limit, and by NIM-based sub-agents.
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# NIM_MODEL is only a last-resort default if the agents below aren't registered.
NIM_MODEL=moonshotai/kimi-k2.6

# ── Role agents (resolved by NAME from .claudbot/agents.yaml) ──
# Which registered sub-agent handles each background role. Defaults shown.
# The fallback REPL (when Claude hits its limit) and the dream loop deliberately
# use different agents so they never contend for the same model.
CLAUDBOT_FALLBACK_AGENT=agent        # NIM fallback REPL  (default: Kimi K2.6)
CLAUDBOT_DREAM_AGENT=researcher      # background dreaming (default: Nemotron 3 Ultra)
CLAUDBOT_SUMMARY_AGENT=fast          # `recall last` conversation summaries (default: Nemotron Nano)
CLAUDBOT_BRIEFING_AGENT=fast         # morning news curation (default: Nemotron Nano — Ultra is too slow)

# ── Morning dashboard / briefing ──
CLAUDBOT_BRIEFING_INTERVAL_H=6       # hours between digest rebuilds in `briefing --watch`
DASHBOARD_PORT=4500                  # `claudbot dashboard` port
# Night VM (NUC). When set on the PC, every `claudbot` launch quietly pulls the
# VM's overnight dream log and merges the new entries into .claudbot/dream-log.md.
# CLAUDBOT_NIGHT_URL=http://192.168.1.150:4500
# Phase-2 personal connectors (not yet wired — see docs/morning-dashboard.md):
# GMAIL_TOKEN=
# NOTION_API_KEY=
# GCAL_TOKEN=

# ── Default behaviour ──
# full | auto | safe | readonly   (see README → Permission modes)
CLAUDBOT_DEFAULT_MODE=full

# ── Sub-agent API keys (optional) ──
# Only set the ones your agents.yaml actually references. Each agent picks
# its key by env-var NAME via `apiKeyEnv`. Local endpoints (Ollama, LM Studio,
# vLLM) need no key. Examples:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# TOGETHER_API_KEY=
# OPENROUTER_API_KEY=
# XAI_API_KEY=
# COHERE_API_KEY=
# DEEPINFRA_API_KEY=
# FIREWORKS_API_KEY=
# NVIDIA_API_KEY=

# ── Channels: WhatsApp via Twilio (optional) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Only these numbers get answered (comma-separated). Leave empty = anyone (unsafe).
WHATSAPP_ALLOWED_NUMBERS=

# ── Channels: Telegram (optional) ──
TELEGRAM_BOT_TOKEN=
# Only these chat IDs get answered (comma-separated). Leave empty = anyone (unsafe).
TELEGRAM_ALLOWED_CHAT_IDS=
# Optional shared secret; set the same value via Telegram setWebhook.
TELEGRAM_WEBHOOK_SECRET=

# ── Channels: Discord / Slack (stored for future use) ──
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=

# ── Channel server ──
CHANNEL_PORT=3000
